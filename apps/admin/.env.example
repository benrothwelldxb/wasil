# API
VITE_API_URL="http://localhost:4000"

# Parent app (used to bounce parent accounts that hit the admin app)
VITE_PARENT_URL="http://localhost:3000"

# Wasil Hub SSO (staff sign-in)
# 'hub'    — unauthenticated staff are redirected to Hub to sign in (default, current behaviour).
# 'legacy' — show Connect's own password/OAuth login page (rollback path).
VITE_STAFF_AUTH_MODE="hub"

# Where unauthenticated staff are sent to sign in. Hub redirects back to
# this app's /auth/callback?code=... once sign-in completes.
VITE_HUB_LAUNCH_URL="https://hub.wasil.app/launch/connect"
