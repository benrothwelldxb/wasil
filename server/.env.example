# Database
DATABASE_URL="postgresql://user:password@localhost:5432/wasil?schema=public"

# Session
SESSION_SECRET="your-super-secret-session-key-change-in-production"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Microsoft OAuth
MICROSOFT_CLIENT_ID="your-microsoft-client-id"
MICROSOFT_CLIENT_SECRET="your-microsoft-client-secret"
MICROSOFT_TENANT_ID="common"

# CORS
CORS_ORIGIN="http://localhost:3000"

# Server
PORT=4000
NODE_ENV=development

# Wasil Hub SSO (ecosystem identity provider)
# All optional-with-defaults so dev/tests run without them. Hub mints a
# 5-minute RS256 JWT and redirects to /auth/hub/exchange?hub_token=<JWT>.
HUB_URL="https://hub.wasil.app"          # Hub base URL (used to derive JWKS URL)
HUB_ISSUER="https://hub.wasil.app"       # expected JWT `iss`
HUB_AUDIENCE="wasil-connect"             # expected JWT `aud`
# HUB_JWKS_URL="https://hub.wasil.app/.well-known/jwks.json"  # optional override; defaults to ${HUB_URL}/.well-known/jwks.json
# HUB_LAUNCH_URL="https://hub.wasil.app/launch/connect"       # where to send unauthenticated staff to (re-)enter via Hub

# Wasil Hub MIS sync (Stage 2 — pull pupils/staff/classes/year-groups)
# HUB_MIS_URL="https://hub.wasil.app"      # Hub MIS API base; defaults to ${HUB_URL} then https://hub.wasil.app
# HUB_SERVICE_TOKEN="wsk_..."              # per-app Bearer service token. NOT issued yet — sync throws a clear
#                                          # "service token not configured" error until it's set.
# HUB_WEBHOOK_SECRET="..."                 # shared secret for verifying X-Wasil-Signature on POST /api/hub/webhook
